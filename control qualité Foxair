<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FOXAIR — Contrôle Qualité Usine</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --bg2: #111317;
    --bg3: #181b21;
    --border: #2a2d35;
    --accent: #f4a020;
    --accent2: #e05c10;
    --green: #2ecc71;
    --red: #e74c3c;
    --blue: #3498db;
    --text: #e8eaf0;
    --muted: #6b7280;
    --card: #13161c;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HEADER */
  header {
    background: var(--bg2);
    border-bottom: 2px solid var(--accent);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    letter-spacing: 4px;
    color: var(--accent);
    text-shadow: 0 0 30px rgba(244,160,32,0.4);
  }

  .logo span {
    color: var(--text);
    font-size: 1rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 2px;
    display: block;
    line-height: 1;
    margin-top: -6px;
    color: var(--muted);
  }

  .header-right {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .badge-live {
    background: var(--green);
    color: #000;
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    padding: 4px 10px;
    border-radius: 2px;
    font-weight: 500;
    animation: pulse 2s infinite;
    letter-spacing: 1px;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* NAV */
  nav {
    display: flex;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    gap: 0;
  }

  .nav-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 1rem 2rem;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-btn:hover { color: var(--text); }
  .nav-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .nav-count {
    background: var(--accent);
    color: #000;
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    padding: 2px 6px;
    border-radius: 2px;
    font-weight: 700;
    min-width: 20px;
    text-align: center;
  }

  /* VIEWS */
  .view { display: none; padding: 2rem; max-width: 1100px; margin: 0 auto; }
  .view.active { display: block; }

  /* SCANNER VIEW */
  .scan-hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .scan-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    letter-spacing: 6px;
    color: var(--text);
    line-height: 1;
  }

  .scan-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 3px;
    margin-top: 0.5rem;
  }

  .scanner-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3rem 2rem;
    margin: 2rem auto;
    max-width: 600px;
    position: relative;
    overflow: hidden;
  }

  .scanner-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: scanline 2.5s ease-in-out infinite;
  }

  @keyframes scanline {
    0% { top: 0; opacity: 1; }
    50% { top: 100%; opacity: 0.5; }
    100% { top: 0; opacity: 1; }
  }

  .camera-area {
    width: 100%;
    height: 220px;
    background: #05070a;
    border: 1px dashed var(--border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  #camera-feed {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
    position: absolute;
    top: 0; left: 0;
  }

  .camera-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .scan-frame {
    width: 200px;
    height: 100px;
    border: 2px solid var(--accent);
    position: relative;
    border-radius: 2px;
  }

  .scan-frame::before, .scan-frame::after {
    content: '';
    position: absolute;
    width: 20px; height: 20px;
    border-color: var(--accent2);
    border-style: solid;
  }

  .scan-frame::before { top: -2px; left: -2px; border-width: 3px 0 0 3px; }
  .scan-frame::after { bottom: -2px; right: -2px; border-width: 0 3px 3px 0; }

  .scan-beam {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: rgba(244,160,32,0.7);
    animation: beam 1.5s ease-in-out infinite;
    top: 10%;
  }

  @keyframes beam {
    0%, 100% { top: 10%; }
    50% { top: 85%; }
  }

  .camera-icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    opacity: 0.3;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 2px;
  }

  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .input-row {
    display: flex;
    gap: 0.75rem;
  }

  .foxair-input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    padding: 0.85rem 1.2rem;
    letter-spacing: 2px;
    outline: none;
    transition: border-color 0.2s;
  }

  .foxair-input:focus { border-color: var(--accent); }
  .foxair-input::placeholder { color: var(--muted); letter-spacing: 1px; font-size: 0.85rem; }

  .btn-primary {
    background: var(--accent);
    color: #000;
    border: none;
    padding: 0.85rem 2rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--accent2);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(244,160,32,0.3);
  }

  .btn-cam {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.75rem 1.5rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .btn-cam:hover { border-color: var(--accent); color: var(--accent); }

  /* RECENT MACHINES */
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .recent-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem 1.25rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .recent-card:hover { border-color: var(--accent); }
  .recent-card-id { font-family: 'DM Mono', monospace; font-size: 0.9rem; color: var(--accent); }
  .recent-card-model { font-size: 0.85rem; color: var(--muted); margin-top: 2px; }
  .recent-card-status { font-size: 0.7rem; font-family: 'DM Mono', monospace; margin-top: 6px; }
  .status-done { color: var(--green); }
  .status-progress { color: var(--accent); }

  /* CHECKLIST VIEW */
  .machine-header {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .machine-id {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    letter-spacing: 4px;
    color: var(--accent);
  }

  .machine-meta { display: flex; flex-direction: column; gap: 4px; }
  .machine-meta span { font-size: 0.85rem; color: var(--muted); font-family: 'DM Mono', monospace; }
  .machine-meta strong { color: var(--text); }

  .progress-ring {
    width: 80px;
    height: 80px;
    position: relative;
  }

  .progress-ring svg { transform: rotate(-90deg); }
  .progress-ring circle { fill: none; stroke-width: 6; }
  .ring-bg { stroke: var(--border); }
  .ring-fill { stroke: var(--accent); stroke-linecap: round; transition: stroke-dashoffset 0.5s; }
  .progress-pct {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent);
  }

  /* SECTIONS */
  .checklist-section {
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 3px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .section-icon { color: var(--accent); font-size: 1.1rem; }

  .check-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .check-item.validated {
    border-color: rgba(46,204,113,0.4);
    background: rgba(46,204,113,0.05);
  }

  .check-item.validated::after {
    content: '✓ VALIDÉ';
    position: absolute;
    right: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--green);
    letter-spacing: 2px;
  }

  .check-item.critical { border-left: 3px solid var(--red); }
  .check-item.critical.validated { border-left-color: var(--green); }

  .check-checkbox {
    width: 24px;
    height: 24px;
    border: 2px solid var(--border);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s;
    background: var(--bg);
  }

  .check-checkbox:hover { border-color: var(--accent); }
  .check-checkbox.checked {
    background: var(--green);
    border-color: var(--green);
  }

  .check-checkbox.checked::after {
    content: '✓';
    color: #000;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .check-content { flex: 1; }

  .check-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--text);
  }

  .check-desc {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    margin-top: 2px;
  }

  .check-tags { display: flex; gap: 0.4rem; margin-top: 6px; }

  .tag {
    font-size: 0.6rem;
    font-family: 'DM Mono', monospace;
    padding: 2px 7px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tag-critical { background: rgba(231,76,60,0.2); color: var(--red); border: 1px solid rgba(231,76,60,0.3); }
  .tag-electrical { background: rgba(52,152,219,0.2); color: var(--blue); border: 1px solid rgba(52,152,219,0.3); }
  .tag-pneumatic { background: rgba(244,160,32,0.2); color: var(--accent); border: 1px solid rgba(244,160,32,0.3); }
  .tag-safety { background: rgba(231,76,60,0.15); color: #ff8a80; border: 1px solid rgba(231,76,60,0.2); }
  .tag-visual { background: rgba(155,89,182,0.2); color: #bf8fff; border: 1px solid rgba(155,89,182,0.3); }

  .btn-validate {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.5rem 1.2rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .btn-validate:hover { border-color: var(--green); color: var(--green); }
  .btn-validate.validated-btn {
    background: rgba(46,204,113,0.15);
    border-color: var(--green);
    color: var(--green);
    cursor: default;
  }

  /* NOTES FIELD */
  .check-note-area {
    margin-top: 0.5rem;
    display: none;
  }

  .check-note-area.visible { display: block; }

  .note-input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    resize: none;
    outline: none;
    transition: border-color 0.2s;
    height: 60px;
  }

  .note-input:focus { border-color: var(--accent); }

  /* BOTTOM BAR */
  .checklist-actions {
    position: sticky;
    bottom: 0;
    background: var(--bg2);
    border-top: 2px solid var(--border);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 -2rem;
  }

  .progress-text {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .progress-text strong { color: var(--accent); }

  .btn-finalize {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
    border: none;
    padding: 0.9rem 2.5rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 3px;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .btn-finalize:disabled {
    background: var(--border);
    color: var(--muted);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .btn-finalize:not(:disabled):hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(244,160,32,0.4);
  }

  /* REGISTRY VIEW */
  .registry-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .registry-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    letter-spacing: 5px;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1.25rem;
    text-align: center;
  }

  .stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 2px;
    margin-top: 4px;
    text-transform: uppercase;
  }

  .search-bar {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .search-icon { color: var(--muted); font-size: 1rem; }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    outline: none;
    letter-spacing: 1px;
  }

  .search-input::placeholder { color: var(--muted); }

  .registry-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .registry-table th {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    background: var(--bg3);
  }

  .registry-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(42,45,53,0.5);
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    vertical-align: middle;
  }

  .registry-table tr:hover td { background: rgba(255,255,255,0.02); }

  .td-id { color: var(--accent); font-weight: 500; font-size: 0.95rem; }
  .td-model { color: var(--text); }
  .td-date { color: var(--muted); font-size: 0.8rem; }

  .badge-ok {
    background: rgba(46,204,113,0.15);
    color: var(--green);
    border: 1px solid rgba(46,204,113,0.3);
    padding: 3px 10px;
    border-radius: 2px;
    font-size: 0.7rem;
    letter-spacing: 1px;
  }

  .badge-nc {
    background: rgba(231,76,60,0.15);
    color: var(--red);
    border: 1px solid rgba(231,76,60,0.3);
    padding: 3px 10px;
    border-radius: 2px;
    font-size: 0.7rem;
    letter-spacing: 1px;
  }

  .badge-partial {
    background: rgba(244,160,32,0.15);
    color: var(--accent);
    border: 1px solid rgba(244,160,32,0.3);
    padding: 3px 10px;
    border-radius: 2px;
    font-size: 0.7rem;
    letter-spacing: 1px;
  }

  .btn-detail {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 4px 12px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.2s;
  }

  .btn-detail:hover { border-color: var(--accent); color: var(--accent); }

  /* MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    backdrop-filter: blur(3px);
  }

  .modal-overlay.active { display: flex; }

  .modal {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    border-radius: 4px;
    padding: 2rem;
    max-width: 700px;
    width: 100%;
    max-height: 80vh;
    overflow-y: auto;
    position: relative;
  }

  .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 4px;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .modal-close {
    position: absolute;
    top: 1rem; right: 1rem;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: color 0.2s;
  }

  .modal-close:hover { color: var(--text); }

  .modal-task-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .modal-task {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: var(--card);
    border-radius: 3px;
    border: 1px solid var(--border);
    font-size: 0.85rem;
  }

  .modal-task.ok { border-color: rgba(46,204,113,0.3); }
  .modal-task.ok .task-icon { color: var(--green); }
  .modal-task.fail { border-color: rgba(231,76,60,0.3); }
  .modal-task.fail .task-icon { color: var(--red); }

  .task-icon { font-size: 0.9rem; flex-shrink: 0; }

  /* TOAST */
  .toast {
