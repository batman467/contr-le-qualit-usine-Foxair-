  if (name === 'registry') renderRegistry();
}

// ======================================================
// CAMERA / BARCODE
// ======================================================
async function toggleCamera() {
  const btn = document.getElementById('btn-cam');
  const feed = document.getElementById('camera-feed');
  const placeholder = document.getElementById('camera-placeholder');
  const frameOverlay = document.getElementById('scan-frame-overlay');

  if (cameraStream) {
    stopCamera();
    return;
  }

  try {
    cameraStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: 640, height: 480 }
    });
    feed.srcObject = cameraStream;
    feed.style.display = 'block';
    placeholder.style.display = 'none';
    frameOverlay.style.display = 'flex';
    btn.textContent = '⏹ Arrêter la caméra';
    btn.style.borderColor = 'var(--red)';
    btn.style.color = 'var(--red)';
    startBarcodeDetection(feed);
  } catch(e) {
    showToast('Caméra inaccessible — utilisez la saisie manuelle', 'error');
  }
}

function stopCamera() {
  if (cameraStream) {
    cameraStream.getTracks().forEach(t => t.stop());
    cameraStream = null;
  }
  clearInterval(barcodeInterval);
  const feed = document.getElementById('camera-feed');
  feed.style.display = 'none';
  document.getElementById('camera-placeholder').style.display = 'flex';
  document.getElementById('scan-frame-overlay').style.display = 'none';
  const btn = document.getElementById('btn-cam');
  btn.textContent = '📷 Activer la caméra pour scanner';
  btn.style.borderColor = '';
  btn.style.color = '';
}

function startBarcodeDetection(video) {
  if (!('BarcodeDetector' in window)) {
    showToast('BarcodeDetector non supporté — saisie manuelle disponible', 'warning');
    return;
  }
  const detector = new BarcodeDetector({ formats: ['code_128', 'code_39', 'ean_13', 'qr_code', 'data_matrix'] });
  barcodeInterval = setInterval(async () => {
    if (video.readyState === video.HAVE_ENOUGH_DATA) {
      try {
        const barcodes = await detector.detect(video);
        if (barcodes.length > 0) {
          const raw = barcodes[0].rawValue.trim().toUpperCase();
          document.getElementById('serial-input').value = raw;
          stopCamera();
          showToast('✓ Code scanné : ' + raw, 'success');
          setTimeout(() => loadMachine(), 500);
        }
      } catch(e) {}
    }
  }, 300);
}

