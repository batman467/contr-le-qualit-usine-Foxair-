  if (!techInput) { showToast('Saisissez le nom du technicien', 'error'); document.getElementById('tech-input').focus(); return; }

  // Save tech to recent list
  if (!TECH_NAMES.includes(techInput)) TECH_NAMES.push(techInput);

  const existing = registry.find(m => m.id === raw);
  const model = existing ? existing.model : MODELS[Math.floor(Math.random() * MODELS.length)];

  currentMachine = {
    id: raw,
    model: model,
    tech: techInput,
    date: new Date().toLocaleDateString('fr-FR'),
    timestamp: Date.now()
  };

  checkedItems = {};
  if (existing && existing.checkedItems) {
    checkedItems = { ...existing.checkedItems };
  }

  buildChecklist();
  updateProgress();
  updateMachineHeader();
  showView('checklist');
  document.getElementById('serial-input').value = '';
  document.getElementById('tech-input').value = '';

  const navCount = document.getElementById('checklist-count');
  navCount.style.display = 'inline';
  updateRecentGrid();
}

// ======================================================
// CHECKLIST
// ======================================================
function buildChecklist() {
  const container = document.getElementById('checklist-container');
  container.innerHTML = '';

  CHECKLIST.forEach(section => {
    const sDiv = document.createElement('div');
    sDiv.className = 'checklist-section';

    const titleEl = document.createElement('div');
    titleEl.className = 'section-title';
    titleEl.textContent = section.section;
    sDiv.appendChild(titleEl);

    section.items.forEach(item => {
      const isChecked = !!checkedItems[item.id];
      const el = document.createElement('div');
      el.className = 'check-item' + (item.critical ? ' critical' : '') + (isChecked ? ' validated' : '');
      el.id = 'item-' + item.id;

      const tagHTML = item.tags.map(t => `<span class="tag tag-${t}">${t}</span>`).join('');

      el.innerHTML = `
        <div class="check-checkbox ${isChecked ? 'checked' : ''}" id="cb-${item.id}" onclick="toggleCheck('${item.id}')"></div>
        <div class="check-content">
          <div class="check-name">${item.name}</div>
          <div class="check-desc">${item.desc}</div>
          <div class="check-tags">${tagHTML}</div>
          <div class="check-note-area ${isChecked ? 'visible' : ''}" id="note-area-${item.id}">
            <textarea class="note-input" id="note-${item.id}" placeholder="Remarque (optionnel)...">${checkedItems[item.id]?.note || ''}</textarea>
          </div>
        </div>
        <button class="btn-validate ${isChecked ? 'validated-btn' : ''}" id="vbtn-${item.id}" onclick="toggleCheck('${item.id}')">
          ${isChecked ? '✓ OK' : 'VALIDER'}
        </button>
      `;

      sDiv.appendChild(el);
    });

    container.appendChild(sDiv);
  });
}

function toggleCheck(id) {
  if (checkedItems[id]) {
    delete checkedItems[id];
    document.getElementById('cb-' + id).classList.remove('checked');
    document.getElementById('item-' + id).classList.remove('validated');
    document.getElementById('vbtn-' + id).textContent = 'VALIDER';
    document.getElementById('vbtn-' + id).classList.remove('validated-btn');
    document.getElementById('note-area-' + id).classList.remove('visible');
  } else {
    const note = document.getElementById('note-' + id)?.value || '';
    checkedItems[id] = { ts: Date.now(), note };
    document.getElementById('cb-' + id).classList.add('checked');
    document.getElementById('item-' + id).classList.add('validated');
    document.getElementById('vbtn-' + id).innerHTML = '✓ OK';
    document.getElementById('vbtn-' + id).classList.add('validated-btn');
    document.getElementById('note-area-' + id).classList.add('visible');
    // micro-feedback
    document.getElementById('item-' + id).style.transform = 'scale(1.01)';
    setTimeout(() => { document.getElementById('item-' + id).style.transform = ''; }, 200);
  }
  updateProgress();
  autosave();
}

function updateProgress() {
  const total = CHECKLIST.reduce((a, s) => a + s.items.length, 0);
  const done = Object.keys(checkedItems).length;
  const pct = Math.round(done / total * 100);

  document.getElementById('progress-done').textContent = done;
  document.getElementById('progress-total').textContent = total;
  document.getElementById('progress-pct').textContent = pct + '%';
  document.getElementById('checklist-count').textContent = done + '/' + total;

  const circ = 2 * Math.PI * 34;
  const offset = circ - (pct / 100 * circ);
  document.getElementById('ring-fill').style.strokeDashoffset = offset;

  const btn = document.getElementById('btn-finalize');
  btn.disabled = done < total;
}

function updateMachineHeader() {
  if (!currentMachine) return;
  document.getElementById('mh-id').textContent = currentMachine.id;
  document.getElementById('mh-model').textContent = currentMachine.model;
  document.getElementById('mh-date').textContent = currentMachine.date;
  document.getElementById('mh-tech').textContent = currentMachine.tech;
}

// ======================================================
// AUTOSAVE
// ======================================================
function autosave() {
  if (!currentMachine) return;
  const total = CHECKLIST.reduce((a, s) => a + s.items.length, 0);
  const done = Object.keys(checkedItems).length;
  const existing = registry.findIndex(m => m.id === currentMachine.id);
  const entry = {
    ...currentMachine,
    checkedItems: { ...checkedItems },
    done,
    total,
    status: done === total ? 'OK' : 'partial',
    lastUpdate: Date.now()
  };
  if (existing >= 0) {
    registry[existing] = entry;
  } else {
    registry.unshift(entry);
  }
  localStorage.setItem('foxair_registry', JSON.stringify(registry));
  document.getElementById('registry-count').textContent = registry.length;
}

// ======================================================
// FINALIZE
// ======================================================
function finalizeControl() {
  autosave();
  const certRef = 'CQ-' + currentMachine.id + '-' + Date.now().toString(36).toUpperCase();
  document.getElementById('success-id').textContent = currentMachine.id + ' — ' + currentMachine.model;
  document.getElementById('cert-ref').textContent = '🏷 Réf: ' + certRef;
  document.getElementById('success-overlay').classList.add('active');
}

function closeSuccess() {
  document.getElementById('success-overlay').classList.remove('active');
  currentMachine = null;
  checkedItems = {};
  document.getElementById('checklist-count').style.display = 'none';
  showView('scanner');
  updateRecentGrid();
}

function confirmDelete(id) {
  document.getElementById('delete-id-display').textContent = id;
  document.getElementById('delete-overlay').dataset.targetId = id;
  document.getElementById('delete-overlay').classList.add('active');
}

function deleteMachine() {
  const id = document.getElementById('delete-overlay').dataset.targetId;
  registry = registry.filter(m => m.id !== id);
  localStorage.setItem('foxair_registry', JSON.stringify(registry));
  document.getElementById('delete-overlay').classList.remove('active');
  renderRegistry();
  updateRecentGrid();
  document.getElementById('registry-count').textContent = registry.length;
  showToast('Machine ' + id + ' supprimée', 'error');
}

function closeDeleteModal(e) {
  if (e.target === document.getElementById('delete-overlay'))
    document.getElementById('delete-overlay').classList.remove('active');
}

// ======================================================
// REGISTRY
// ======================================================
function renderRegistry(filter) {
  const tbody = document.getElementById('registry-tbody');
  const empty = document.getElementById('registry-empty');
  const data = filter
    ? registry.filter(m => m.id.includes(filter.toUpperCase()) || m.model.toUpperCase().includes(filter.toUpperCase()) || (m.tech && m.tech.toUpperCase().includes(filter.toUpperCase())))
    : registry;

  tbody.innerHTML = '';

  if (data.length === 0) {
    empty.style.display = 'block';
    tbody.parentElement.style.display = 'none';
  } else {
    empty.style.display = 'none';
    tbody.parentElement.style.display = 'table';
    data.forEach(m => {
      const pct = Math.round((m.done / m.total) * 100);
      const statusBadge = m.status === 'OK'
        ? '<span class="badge-ok">✓ CONFORME</span>'
        : `<span class="badge-partial">${pct}% EN COURS</span>`;

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="td-id">${m.id}</td>
        <td class="td-model">${m.model}</td>
        <td class="td-date">${m.date}</td>
        <td>${m.tech || '—'}</td>
        <td>
          <div style="display:flex;align-items:center;gap:8px">
            <div style="flex:1;height:4px;background:var(--border);border-radius:2px;min-width:60px">
              <div style="height:100%;width:${pct}%;background:${m.status==='OK'?'var(--green)':'var(--accent)'};border-radius:2px;transition:width 0.3s"></div>
            </div>
            <span style="font-size:0.75rem;color:var(--muted);font-family:'DM Mono',monospace">${m.done}/${m.total}</span>
          </div>
        </td>
        <td>${statusBadge}</td>
        <td style="display:flex;gap:0.5rem">
          <button class="btn-detail" onclick="showDetail('${m.id}')">DÉTAIL</button>
          <button class="btn-detail" onclick="confirmDelete('${m.id}')" style="border-color:rgba(231,76,60,0.4);color:var(--red)" onmouseover="this.style.borderColor='var(--red)'" onmouseout="this.style.borderColor='rgba(231,76,60,0.4)'">🗑</button>
        </td>
      `;
      tbody.appendChild(tr);
    });
  }

  // Stats
  const today = new Date().toLocaleDateString('fr-FR');
  document.getElementById('stat-total').textContent = registry.length;
  document.getElementById('stat-ok').textContent = registry.filter(m => m.status === 'OK').length;
  document.getElementById('stat-partial').textContent = registry.filter(m => m.status !== 'OK').length;
  document.getElementById('stat-today').textContent = registry.filter(m => m.date === today).length;
  document.getElementById('registry-count').textContent = registry.length;
}

function filterRegistry(val) {
  renderRegistry(val);
}

function showDetail(id) {
  const m = registry.find(r => r.id === id);
  if (!m) return;

  document.getElementById('modal-title').textContent = id + ' — ' + m.model;

  let html = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;font-family:'DM Mono',monospace;font-size:0.8rem">
      <div><span style="color:var(--muted)">DATE:</span> <strong>${m.date}</strong></div>
      <div><span style="color:var(--muted)">TECH:</span> <strong>${m.tech}</strong></div>
      <div><span style="color:var(--muted)">AVANCEMENT:</span> <strong style="color:var(--accent)">${m.done}/${m.total} (${Math.round(m.done/m.total*100)}%)</strong></div>
      <div><span style="color:var(--muted)">STATUT:</span> <strong style="color:${m.status==='OK'?'var(--green)':'var(--accent)'}">${m.status==='OK'?'CONFORME':'EN COURS'}</strong></div>
    </div>
    <div class="section-label">RÉSULTAT DES VÉRIFICATIONS</div>
    <div class="modal-task-list">
  `;

  CHECKLIST.forEach(section => {
    html += `<div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;color:var(--muted);padding:0.5rem 0 0.25rem;border-top:1px solid var(--border);margin-top:0.5rem">${section.section}</div>`;
    section.items.forEach(item => {
      const ok = !!m.checkedItems?.[item.id];
      const note = m.checkedItems?.[item.id]?.note;
      html += `
        <div class="modal-task ${ok ? 'ok' : 'fail'}">
          <span class="task-icon">${ok ? '✅' : '⬜'}</span>
          <div style="flex:1">
            <div style="font-size:0.9rem">${item.name}</div>
            ${note ? `<div style="font-size:0.75rem;color:var(--muted);font-family:'DM Mono',monospace;margin-top:2px">📝 ${note}</div>` : ''}
          </div>
          ${item.critical ? '<span class="tag tag-critical">CRITIQUE</span>' : ''}
        </div>
      `;
    });
  });

  html += '</div>';
  document.getElementById('modal-content').innerHTML = html;
  document.getElementById('modal-overlay').classList.add('active');
}

function closeModal(e) {
  if (e.target === document.getElementById('modal-overlay')) {
    document.getElementById('modal-overlay').classList.remove('active');
  }
}

// ======================================================
// EXPORT
// ======================================================
function exportRegistry() {
  if (registry.length === 0) { showToast('Aucune donnée à exporter', 'error'); return; }
  let csv = 'N° Série;Modèle;Date;Technicien;Avancement;Statut\n';
  registry.forEach(m => {
    csv += `${m.id};${m.model};${m.date};${m.tech};${m.done}/${m.total};${m.status}\n`;
  });
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'foxair_carnet_machines_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  showToast('Export CSV téléchargé !', 'success');
}

// ======================================================
// RECENT GRID
// ======================================================
function updateRecentGrid() {
  const grid = document.getElementById('recent-grid');
  const recents = registry.slice(0, 8);
  if (recents.length === 0) {
    grid.innerHTML = '<div class="empty-state" style="padding:1rem;grid-column:1/-1"><div class="empty-icon">🏭</div>Aucune machine scannée récemment</div>';
    return;
  }
  grid.innerHTML = recents.map(m => `
    <div class="recent-card" onclick="document.getElementById('serial-input').value='${m.id}';loadMachine()">
      <div class="recent-card-id">${m.id}</div>
      <div class="recent-card-model">${m.model}</div>
      <div class="recent-card-status ${m.status==='OK'?'status-done':'status-progress'}">
        ${m.status==='OK'?'✓ Conforme':'⟳ ' + Math.round(m.done/m.total*100) + '%'}
      </div>
    </div>
  `).join('');
}

// ======================================================
// TOAST
// ======================================================
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast' + (type === 'error' ? ' error' : type === 'warning' ? ' warning' : '');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ======================================================
// INIT
// ======================================================
updateRecentGrid();
document.getElementById('registry-count').textContent = registry.length;
</script>
</body>
</html>
