function filterTechSuggestions(val) {
  const box = document.getElementById('tech-suggestions');
  const all = [...new Set([...TECH_NAMES, ...registry.map(m => m.tech).filter(Boolean)])];
  const filtered = val.length === 0
    ? all
    : all.filter(t => t.toLowerCase().includes(val.toLowerCase()));

  if (filtered.length === 0) { box.style.display = 'none'; return; }

  box.innerHTML = filtered.map(t => `
    <div onclick="selectTech('${t.replace(/'/g,"&#39;")}')"
      style="padding:0.65rem 1.2rem;cursor:pointer;font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--text);transition:background 0.15s"
      onmouseover="this.style.background='rgba(244,160,32,0.1)'"
      onmouseout="this.style.background=''"
    >👤 ${t}</div>
  `).join('');
  box.style.display = 'block';
}

function selectTech(name) {
  document.getElementById('tech-input').value = name;
  document.getElementById('tech-suggestions').style.display = 'none';
}

